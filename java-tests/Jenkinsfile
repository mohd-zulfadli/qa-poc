pipeline {
    agent any
    environment {
        JAVA_HOME = '/Library/Java/JavaVirtualMachines/jdk-1.8.jdk/Contents/Home'
        PATH = "${JAVA_HOME}/bin:${env.PATH}"
    }
    stages {
        stage('TestNG Tests') {
            steps {
                dir('java-tests') {
                    sh 'mvn clean test -Dtest=com.example.tests.Scenario1Test#testLogin,testUpdateDOB'
                }
            }
        }
    }
    post {
        always {
            junit 'java-tests/target/surefire-reports/*.xml'
            publishHTML([
                reportDir: 'java-tests/target/surefire-reports',
                reportFiles: 'emailable-report.html',
                reportName: 'TestNG Report',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: false
            ])
            archiveArtifacts artifacts: 'java-tests/target/surefire-reports/**', fingerprint: true
        }
    }
}
