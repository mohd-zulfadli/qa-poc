pipeline {
    agent any
    stages {
        stage('Karate Functional Tests') {
            steps {
                sh 'mvn clean karate:test -pl karate-tests -am -Dkarate.options="--tags @BASIC_API"'
            }
        }
    //     stage('Karate Functional Tests') {
    //         steps {
    //             sh 'mvn clean test -pl karate-tests -am -Dkarate.options="--tags @BASIC_API"'
    //         }
    //     }
    // }
    post {
        always {
            // Publish JUnit XML results so Jenkins can show pass/fail counts
            junit 'karate-tests/target/surefire-reports/*.xml'

            // Publish Karate HTML report inline on the build summary page
            publishHTML([
                reportDir: 'karate-tests/target/karate-reports',
                reportFiles: 'karate-summary.html',
                reportName: 'Karate Test Report',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: false
            ])

            // Optionally archive the raw report files for download
            archiveArtifacts artifacts: 'karate-tests/target/karate-reports/**', fingerprint: true
        }
    }
}
