pipeline {
    agent any
    stages {
        stage('Performance Tests') {
            steps {
                sh 'mvn clean gatling:test -pl karate-tests -am -Dgatling.simulationClass=com.example.PerfTest'
            }
        }
    }
    post {
        always {
            // Archive all Gatling results as build artifacts
            archiveArtifacts artifacts: 'karate-tests/target/gatling/**', fingerprint: true

            // Use Gatling Jenkins plugin to publish the latest report
            gatlingArchive()
        }
    }
}
