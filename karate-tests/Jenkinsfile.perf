pipeline {
    agent any
    stages {
        stage('Performance Tests') {
            steps {
                sh 'mvn clean gatling:test -pl karate-tests -am -Dgatling.simulationClass=com.example.PerfTest'
            }
        }
    }
    post {
        always {
            // Archive all Gatling results as build artifacts
            archiveArtifacts artifacts: 'karate-tests/target/gatling/**', fingerprint: true

            // Publish the latest Gatling report inline on the build page
            script {
                // Find the newest Gatling results folder
                def gatlingDir = sh(
                    script: "ls -td karate-tests/target/gatling/*/ | head -1",
                    returnStdout: true
                ).trim()

                publishHTML([
                    reportDir: gatlingDir,
                    reportFiles: 'index.html',
                    reportName: 'Gatling Performance Report',
                    keepAll: true,
                    alwaysLinkToLastBuild: true,
                    allowMissing: false
                ])
            }
        }
    }
}
